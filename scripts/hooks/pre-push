#!/usr/bin/env bash
# pre-push: deploy to EC2 before pushing to GitHub.
# If the deploy fails, the push is aborted.
set -euo pipefail

echo "▸ pre-push: deploying to EC2…"

if ! make ec2-deploy; then
  echo "✗ EC2 deploy failed — push aborted." >&2
  exit 1
fi

echo "✓ EC2 deploy succeeded — proceeding with push."