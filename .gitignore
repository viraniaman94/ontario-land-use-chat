# Skill content kept out of git and synced to EC2 via rsync — too large or
# reference-only (PDFs/converted markdown + report example templates).
# The skill scaffolding (skill/SKILL.md, skill/references/) IS tracked;
# skill/documents/ (planning docs) and skill/templates/ (report templates +
# examples) are excluded and synced via `make ec2-sync-docs` / `make
# ec2-sync-templates`, or automatically during `make ec2-deploy`.
/skill/documents/
/skill/templates/

# Next.js build output (migrated away, but keep ignored)
/.next/

# SQLite kanban board sidecar files (the .db itself is tracked)
*.db-wal
*.db-shm
*.db-journal

# Pi subagent artifacts
pi-response-formatting-guide.md
.pi-subagents/
.dev.vars
# SSH keys
*.pem
# Cloudflare
er-configuration.d.ts
.wrangler/
