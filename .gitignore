# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Cloudflare quick tunnel runtime artifacts (written by deploy/scripts/start-tunnel.sh)
/.tunnel-url.txt
/.tunnel-url.log

# Marker PDF -> Markdown conversion output + quality reports
/converted-docs/
/scripts/convert-report.json
/scripts/convert-report.csv

# Pi subagent artifacts
/.pi-subagents/
